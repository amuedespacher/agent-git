{
  "name": "agent-git",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agent-git": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.tsx",
    "install:cli": "npm run build && npm link",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "unlink:cli": "npm unlink -g agent-git"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.0",
    "execa": "^9.6.0",
    "ink": "^5.2.1",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.104.0",
    "parse-diff": "^0.11.1",
    "react": "^18.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^18.3.12",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
